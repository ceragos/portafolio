---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ShaderBackground from '../components/ShaderBackground.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Privacy Policy | CValenciaIT"
  description="Privacy Policy and Personal Data Processing for CValenciaIT — Jesús Antonio Castañeda Valencia"
>
  <ShaderBackground />
  <Nav />

  <main class="flex-grow z-10 relative pt-32 pb-20">
    <div class="px-margin-desktop max-w-container-max mx-auto">

      <div class="mb-12 fade-in-up">
        <h1 class="font-headline-lg text-headline-lg text-primary-container mb-3" data-i18n="title">
          Privacy Policy &amp; Data Processing
        </h1>
        <p class="font-technical-mono text-technical-mono text-text-muted" data-i18n="updated">
          Last updated: June 23, 2026
        </p>
      </div>

      <div class="glass-panel rounded-xl border border-outline-variant divide-y divide-outline-variant/50 fade-in-up">

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s1.title">1. Controller</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s1.content">
            Jesús Antonio Castañeda Valencia, operating under the trade name <strong>CValenciaIT</strong>, is the data controller for this website.
            Contact: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a> · Cali, Colombia.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s2.title">2. Data We Collect</h2>
          <div class="text-on-surface-variant leading-relaxed space-y-3" data-i18n="s2.content">
            <p><strong class="text-on-surface">Contact form:</strong> name, e-mail address, and message text you submit.</p>
            <p><strong class="text-on-surface">WhatsApp Business:</strong> when you message us via WhatsApp, Meta processes your phone number, display name, and message content.</p>
            <p><strong class="text-on-surface">Server logs:</strong> your IP address, browser type, and request timestamp are recorded by the web server for security and operational purposes.</p>
            <p><strong class="text-on-surface">Browser local storage:</strong> we store your language preference (<code class="tech-pill px-2 py-0.5 rounded text-xs">lang</code>) locally in your browser. This value is never transmitted to our servers.</p>
          </div>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s3.title">3. Purpose</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s3.content">
            We use your data exclusively to respond to your inquiries and service requests; to establish or formalize professional services agreements; and to maintain ongoing communication with clients and prospects.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s4.title">4. Legal Basis</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s4.content">
            Processing is based on your explicit consent provided by voluntarily submitting the contact form or initiating a WhatsApp conversation. For established service relationships, processing is also based on the performance of a contract.
            Applicable law: <strong class="text-on-surface">Colombian Law 1581 of 2012</strong> (Habeas Data) and Decree 1377 of 2013.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s5.title">5. Data Sharing</h2>
          <div class="text-on-surface-variant leading-relaxed space-y-3" data-i18n="s5.content">
            <p>We do not sell, rent, or trade your personal data to third parties. Your data may be shared only with:</p>
            <p><strong class="text-on-surface">Meta Platforms (WhatsApp Business):</strong> Meta processes data transmitted through WhatsApp according to its own Privacy Policy.</p>
            <p><strong class="text-on-surface">Hosting provider:</strong> the VPS provider stores technical server logs. We have no other data-sharing arrangements.</p>
          </div>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s6.title">6. Retention</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s6.content">
            Contact form data is retained for as long as necessary to address your request and for up to five (5) years after our last interaction, unless you request earlier deletion. Server logs are retained for up to 90 days.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s7.title">7. Your Rights</h2>
          <div class="text-on-surface-variant leading-relaxed space-y-3" data-i18n="s7.content">
            <p>Under Colombian Law 1581 of 2012, you have the right to:</p>
            <ul class="list-disc list-inside space-y-1 ml-2">
              <li><strong class="text-on-surface">Know</strong> the personal data we hold about you.</li>
              <li><strong class="text-on-surface">Update and correct</strong> inaccurate data.</li>
              <li><strong class="text-on-surface">Request deletion</strong> of your data.</li>
              <li><strong class="text-on-surface">Revoke your consent</strong> at any time.</li>
            </ul>
            <p>To exercise these rights, contact us at <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a>. We will respond within 15 business days.</p>
          </div>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s8.title">8. WhatsApp &amp; Meta</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s8.content">
            This website may link to or integrate WhatsApp Business channels operated via the Meta Business Platform. Messages sent through WhatsApp are subject to Meta's Terms of Service and Privacy Policy. We are not responsible for how Meta processes your data on their platforms.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s9.title">9. Cookies &amp; Local Storage</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s9.content">
            This website does not use tracking or analytics cookies. We use the browser's <code class="tech-pill px-2 py-0.5 rounded text-xs">localStorage</code> API solely to remember your language preference. This data remains on your device and is never transmitted to our servers. You may clear it at any time through your browser settings.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s10.title">10. Security</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s10.content">
            We implement reasonable technical and organizational measures to protect personal data, including HTTPS encryption for all communications. No method of transmission over the internet is 100% secure; we cannot guarantee absolute security.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s11.title">11. Changes to This Policy</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s11.content">
            We reserve the right to update this Privacy Policy at any time. The effective date at the top of this page reflects the most recent revision. Continued use of this website after changes constitutes acceptance of the updated policy.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s12.title">12. Contact &amp; Complaints</h2>
          <div class="text-on-surface-variant leading-relaxed space-y-2" data-i18n="s12.content">
            <p>For questions about this policy or to exercise your rights: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a></p>
            <p>To file a complaint with the supervisory authority: <strong class="text-on-surface">Superintendencia de Industria y Comercio (SIC)</strong> — <a href="https://www.sic.gov.co" class="text-primary-container hover:underline" target="_blank" rel="noopener noreferrer">www.sic.gov.co</a></p>
          </div>
        </div>

      </div>

      <div class="mt-10 text-center">
        <a href="/" class="font-technical-mono text-technical-mono text-text-muted hover:text-primary-container transition-colors" data-i18n="back">
          ← Back to portfolio
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Base>

<script>
const t: Record<string, Record<'en' | 'es', string>> = {
  // Nav
  'nav.about':      { en: 'About',      es: 'Sobre mí'   },
  'nav.stack':      { en: 'Stack',      es: 'Stack'       },
  'nav.projects':   { en: 'Projects',   es: 'Proyectos'   },
  'nav.experience': { en: 'Experience', es: 'Experiencia' },
  'nav.contact':    { en: 'Contact Me', es: 'Contáctame'  },
  // Footer
  'footer.tagline': { en: 'AI Accelerates; Engineering Decides.', es: 'La IA Acelera; La Ingeniería Decide.' },
  'footer.privacy': { en: 'Privacy', es: 'Privacidad' },
  'footer.terms':   { en: 'Terms',   es: 'Términos'  },
  // Page
  title:    { en: 'Privacy Policy & Data Processing', es: 'Política de Privacidad y Tratamiento de Datos' },
  updated:  { en: 'Last updated: June 23, 2026',      es: 'Última actualización: 23 de junio de 2026'    },
  back:     { en: '← Back to portfolio',              es: '← Volver al portafolio'                       },

  's1.title':   { en: '1. Controller',   es: '1. Responsable del Tratamiento' },
  's1.content': {
    en: 'Jesús Antonio Castañeda Valencia, operating under the trade name <strong>CValenciaIT</strong>, is the data controller for this website. Contact: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a> · Cali, Colombia.',
    es: 'Jesús Antonio Castañeda Valencia, que opera bajo el nombre comercial <strong>CValenciaIT</strong>, es el responsable del tratamiento de datos de este sitio web. Contacto: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a> · Cali, Colombia.',
  },

  's2.title':   { en: '2. Data We Collect',  es: '2. Datos que Recopilamos' },
  's2.content': {
    en: '<p><strong class="text-on-surface">Contact form:</strong> name, e-mail address, and message text you submit.</p><p><strong class="text-on-surface">WhatsApp Business:</strong> when you message us via WhatsApp, Meta processes your phone number, display name, and message content.</p><p><strong class="text-on-surface">Server logs:</strong> your IP address, browser type, and request timestamp are recorded by the web server for security and operational purposes.</p><p><strong class="text-on-surface">Browser local storage:</strong> we store your language preference (<code class="tech-pill px-2 py-0.5 rounded text-xs">lang</code>) locally in your browser. This value is never transmitted to our servers.</p>',
    es: '<p><strong class="text-on-surface">Formulario de contacto:</strong> nombre, correo electrónico y texto del mensaje que usted envíe.</p><p><strong class="text-on-surface">WhatsApp Business:</strong> cuando nos escribe por WhatsApp, Meta procesa su número de teléfono, nombre de perfil y contenido del mensaje.</p><p><strong class="text-on-surface">Registros del servidor:</strong> su dirección IP, tipo de navegador y marca de tiempo de la solicitud quedan registrados en el servidor por razones de seguridad y operación.</p><p><strong class="text-on-surface">Almacenamiento local del navegador:</strong> guardamos su preferencia de idioma (<code class="tech-pill px-2 py-0.5 rounded text-xs">lang</code>) localmente en su navegador. Este valor no se transmite a nuestros servidores.</p>',
  },

  's3.title':   { en: '3. Purpose', es: '3. Finalidad' },
  's3.content': {
    en: 'We use your data exclusively to respond to your inquiries and service requests; to establish or formalize professional services agreements; and to maintain ongoing communication with clients and prospects.',
    es: 'Utilizamos sus datos exclusivamente para responder a sus consultas y solicitudes de servicio; para establecer o formalizar acuerdos de prestación de servicios profesionales; y para mantener comunicación continua con clientes y prospectos.',
  },

  's4.title':   { en: '4. Legal Basis', es: '4. Base Legal' },
  's4.content': {
    en: 'Processing is based on your explicit consent provided by voluntarily submitting the contact form or initiating a WhatsApp conversation. For established service relationships, processing is also based on the performance of a contract. Applicable law: <strong class="text-on-surface">Colombian Law 1581 of 2012</strong> (Habeas Data) and Decree 1377 of 2013.',
    es: 'El tratamiento se basa en el consentimiento expreso que usted otorga al enviar voluntariamente el formulario de contacto o al iniciar una conversación por WhatsApp. Para relaciones de servicio formalizadas, el tratamiento se basa también en la ejecución de un contrato. Ley aplicable: <strong class="text-on-surface">Ley 1581 de 2012</strong> (Habeas Data) y Decreto 1377 de 2013 (Colombia).',
  },

  's5.title':   { en: '5. Data Sharing', es: '5. Compartición de Datos' },
  's5.content': {
    en: '<p>We do not sell, rent, or trade your personal data to third parties. Your data may be shared only with:</p><p><strong class="text-on-surface">Meta Platforms (WhatsApp Business):</strong> Meta processes data transmitted through WhatsApp according to its own Privacy Policy.</p><p><strong class="text-on-surface">Hosting provider:</strong> the VPS provider stores technical server logs. We have no other data-sharing arrangements.</p>',
    es: '<p>No vendemos, alquilamos ni cedemos sus datos personales a terceros. Sus datos solo pueden ser compartidos con:</p><p><strong class="text-on-surface">Meta Platforms (WhatsApp Business):</strong> Meta procesa los datos transmitidos a través de WhatsApp conforme a su propia Política de Privacidad.</p><p><strong class="text-on-surface">Proveedor de alojamiento:</strong> el proveedor del VPS almacena registros técnicos del servidor. No tenemos ningún otro acuerdo de compartición de datos.</p>',
  },

  's6.title':   { en: '6. Retention', es: '6. Conservación' },
  's6.content': {
    en: 'Contact form data is retained for as long as necessary to address your request and for up to five (5) years after our last interaction, unless you request earlier deletion. Server logs are retained for up to 90 days.',
    es: 'Los datos del formulario de contacto se conservan durante el tiempo necesario para atender su solicitud y hasta cinco (5) años después de nuestro último contacto, salvo que solicite su eliminación antes. Los registros del servidor se conservan hasta 90 días.',
  },

  's7.title':   { en: '7. Your Rights', es: '7. Sus Derechos' },
  's7.content': {
    en: '<p>Under Colombian Law 1581 of 2012, you have the right to:</p><ul class="list-disc list-inside space-y-1 ml-2"><li><strong class="text-on-surface">Know</strong> the personal data we hold about you.</li><li><strong class="text-on-surface">Update and correct</strong> inaccurate data.</li><li><strong class="text-on-surface">Request deletion</strong> of your data.</li><li><strong class="text-on-surface">Revoke your consent</strong> at any time.</li></ul><p>Contact us at <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a>. We will respond within 15 business days.</p>',
    es: '<p>De conformidad con la Ley 1581 de 2012, usted tiene derecho a:</p><ul class="list-disc list-inside space-y-1 ml-2"><li><strong class="text-on-surface">Conocer</strong> los datos personales que conservamos sobre usted.</li><li><strong class="text-on-surface">Actualizar y rectificar</strong> datos inexactos.</li><li><strong class="text-on-surface">Solicitar la supresión</strong> de sus datos.</li><li><strong class="text-on-surface">Revocar su consentimiento</strong> en cualquier momento.</li></ul><p>Contáctenos en <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a>. Responderemos en un plazo de 15 días hábiles.</p>',
  },

  's8.title':   { en: '8. WhatsApp & Meta', es: '8. WhatsApp y Meta' },
  's8.content': {
    en: 'This website may link to or integrate WhatsApp Business channels operated via the Meta Business Platform. Messages sent through WhatsApp are subject to Meta\'s Terms of Service and Privacy Policy. We are not responsible for how Meta processes your data on their platforms.',
    es: 'Este sitio web puede enlazar o integrar canales de WhatsApp Business operados a través de Meta Business Platform. Los mensajes enviados por WhatsApp están sujetos a las Condiciones del Servicio y la Política de Privacidad de Meta. No somos responsables del tratamiento que Meta realice de sus datos en sus plataformas.',
  },

  's9.title':   { en: '9. Cookies & Local Storage', es: '9. Cookies y Almacenamiento Local' },
  's9.content': {
    en: 'This website does not use tracking or analytics cookies. We use the browser\'s <code class="tech-pill px-2 py-0.5 rounded text-xs">localStorage</code> API solely to remember your language preference. This data remains on your device and is never transmitted to our servers. You may clear it at any time through your browser settings.',
    es: 'Este sitio web no utiliza cookies de seguimiento ni analíticas. Usamos la API <code class="tech-pill px-2 py-0.5 rounded text-xs">localStorage</code> del navegador únicamente para recordar su preferencia de idioma. Este dato permanece en su dispositivo y nunca se transmite a nuestros servidores. Puede eliminarlo en cualquier momento desde la configuración de su navegador.',
  },

  's10.title':   { en: '10. Security', es: '10. Seguridad' },
  's10.content': {
    en: 'We implement reasonable technical and organizational measures to protect personal data, including HTTPS encryption for all communications. No method of transmission over the internet is 100% secure; we cannot guarantee absolute security.',
    es: 'Implementamos medidas técnicas y organizativas razonables para proteger los datos personales, incluyendo cifrado HTTPS en todas las comunicaciones. Ningún método de transmisión por internet es 100% seguro; no podemos garantizar seguridad absoluta.',
  },

  's11.title':   { en: '11. Changes to This Policy', es: '11. Modificaciones' },
  's11.content': {
    en: 'We reserve the right to update this Privacy Policy at any time. The effective date at the top of this page reflects the most recent revision. Continued use of this website after changes constitutes acceptance of the updated policy.',
    es: 'Nos reservamos el derecho de actualizar esta Política de Privacidad en cualquier momento. La fecha de última actualización indicada al inicio de esta página refleja la revisión más reciente. El uso continuado de este sitio web después de los cambios implica la aceptación de la política actualizada.',
  },

  's12.title':   { en: '12. Contact & Complaints', es: '12. Contacto y Reclamaciones' },
  's12.content': {
    en: '<p>For questions about this policy or to exercise your rights: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a></p><p>To file a complaint with the supervisory authority: <strong class="text-on-surface">Superintendencia de Industria y Comercio (SIC)</strong> — <a href="https://www.sic.gov.co" class="text-primary-container hover:underline" target="_blank" rel="noopener noreferrer">www.sic.gov.co</a></p>',
    es: '<p>Para consultas sobre esta política o para ejercer sus derechos: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a></p><p>Para reclamaciones ante la autoridad de control: <strong class="text-on-surface">Superintendencia de Industria y Comercio (SIC)</strong> — <a href="https://www.sic.gov.co" class="text-primary-container hover:underline" target="_blank" rel="noopener noreferrer">www.sic.gov.co</a></p>',
  },
};

type Lang = 'en' | 'es';

function apply(lang: Lang) {
  document.documentElement.lang = lang;
  localStorage.setItem('lang', lang);
  document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
    const key = el.dataset.i18n!;
    if (t[key]?.[lang] !== undefined) el.innerHTML = t[key][lang];
  });
  document.querySelectorAll<HTMLElement>('.lang-toggle').forEach((btn) => {
    btn.textContent = lang === 'en' ? 'ES' : 'EN';
  });
}

const lang = (localStorage.getItem('lang') as Lang) ?? 'en';
apply(lang);
document.querySelectorAll('.lang-toggle').forEach((btn) => {
  btn.addEventListener('click', () => {
    apply((localStorage.getItem('lang') as Lang) === 'en' ? 'es' : 'en');
  });
});
</script>
