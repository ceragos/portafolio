---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import ShaderBackground from '../components/ShaderBackground.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Terms & Conditions | CValenciaIT"
  description="Terms and Conditions of Use for CValenciaIT — Jesús Antonio Castañeda Valencia"
>
  <ShaderBackground />
  <Nav />

  <main class="flex-grow z-10 relative pt-32 pb-20">
    <div class="px-margin-desktop max-w-container-max mx-auto">

      <div class="mb-12 fade-in-up">
        <h1 class="font-headline-lg text-headline-lg text-primary-container mb-3" data-i18n="title">
          Terms &amp; Conditions of Use
        </h1>
        <p class="font-technical-mono text-technical-mono text-text-muted" data-i18n="updated">
          Last updated: June 23, 2026
        </p>
      </div>

      <div class="glass-panel rounded-xl border border-outline-variant divide-y divide-outline-variant/50 fade-in-up">

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s1.title">1. Acceptance</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s1.content">
            By accessing and using this website, you agree to be bound by these Terms &amp; Conditions. If you do not agree with any part of these terms, please discontinue use of this website.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s2.title">2. Description of Service</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s2.content">
            This website is the professional portfolio of Jesús Antonio Castañeda Valencia, operating under the trade name <strong>CValenciaIT</strong>. Its purpose is informational — to present professional experience, skills, and projects. Content on this site does not constitute a binding offer of services.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s3.title">3. Intellectual Property</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s3.content">
            All content on this website — including texts, design, visual identity, source code, and the CValenciaIT brand — is the exclusive property of Jesús Antonio Castañeda Valencia, protected under Colombian intellectual property law. Reproduction, distribution, or modification of any content without prior written consent is prohibited. Project descriptions referencing third-party organizations are used for attribution purposes only.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s4.title">4. Acceptable Use</h2>
          <div class="text-on-surface-variant leading-relaxed" data-i18n="s4.content">
            <p class="mb-3">You agree not to use this website:</p>
            <ul class="list-disc list-inside space-y-1 ml-2">
              <li>For any unlawful purpose or in violation of Colombian or international law.</li>
              <li>To attempt to gain unauthorized access to the server or any associated systems.</li>
              <li>To transmit malicious code or interfere with the proper functioning of the website.</li>
              <li>To impersonate any person or entity.</li>
            </ul>
          </div>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s5.title">5. Disclaimer of Warranties</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s5.content">
            This website is provided "as is" and "as available" without warranties of any kind, either express or implied. We do not warrant that the website will be uninterrupted, error-free, or free of viruses or other harmful components.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s6.title">6. Limitation of Liability</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s6.content">
            To the fullest extent permitted by applicable law, CValenciaIT shall not be liable for any direct, indirect, incidental, special, or consequential damages arising from your use of, or inability to use, this website or its content.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s7.title">7. Third-Party Links</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s7.content">
            This website contains links to external websites (GitHub, LinkedIn, Meta/WhatsApp). These links are provided for convenience only. We have no control over and assume no responsibility for the content, privacy policies, or practices of any third-party websites.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s8.title">8. WhatsApp Business</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s8.content">
            Any WhatsApp Business channels linked from this website are subject to the WhatsApp Terms of Service and Meta's Supplemental Terms for Business. By initiating a conversation via WhatsApp, you acknowledge and accept those terms.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s9.title">9. Modifications</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s9.content">
            We reserve the right to modify these Terms &amp; Conditions at any time. Changes take effect immediately upon posting. Your continued use of this website after any changes constitutes acceptance of the revised terms.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s10.title">10. Governing Law &amp; Jurisdiction</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s10.content">
            These Terms &amp; Conditions are governed by and construed in accordance with the laws of the <strong>Republic of Colombia</strong>. Any disputes arising from or relating to these terms shall be subject to the exclusive jurisdiction of the courts of the city of Cali, Colombia.
          </p>
        </div>

        <div class="p-8 md:p-10">
          <h2 class="font-headline-md text-xl text-primary-container mb-4" data-i18n="s11.title">11. Contact</h2>
          <p class="text-on-surface-variant leading-relaxed" data-i18n="s11.content">
            For any questions regarding these Terms &amp; Conditions: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a>
          </p>
        </div>

      </div>

      <div class="mt-10 text-center">
        <a href="/" class="font-technical-mono text-technical-mono text-text-muted hover:text-primary-container transition-colors" data-i18n="back">
          ← Back to portfolio
        </a>
      </div>

    </div>
  </main>

  <Footer />
</Base>

<script>
const t: Record<string, Record<'en' | 'es', string>> = {
  // Nav
  'nav.about':      { en: 'About',      es: 'Sobre mí'   },
  'nav.stack':      { en: 'Stack',      es: 'Stack'       },
  'nav.projects':   { en: 'Projects',   es: 'Proyectos'   },
  'nav.experience': { en: 'Experience', es: 'Experiencia' },
  'nav.contact':    { en: 'Contact Me', es: 'Contáctame'  },
  // Footer
  'footer.tagline': { en: 'AI Accelerates; Engineering Decides.', es: 'La IA Acelera; La Ingeniería Decide.' },
  'footer.privacy': { en: 'Privacy', es: 'Privacidad' },
  'footer.terms':   { en: 'Terms',   es: 'Términos'  },
  // Page
  title:   { en: 'Terms & Conditions of Use',    es: 'Términos y Condiciones de Uso'  },
  updated: { en: 'Last updated: June 23, 2026',  es: 'Última actualización: 23 de junio de 2026' },
  back:    { en: '← Back to portfolio',          es: '← Volver al portafolio'         },

  's1.title':   { en: '1. Acceptance',          es: '1. Aceptación'           },
  's1.content': {
    en: 'By accessing and using this website, you agree to be bound by these Terms & Conditions. If you do not agree with any part of these terms, please discontinue use of this website.',
    es: 'Al acceder y utilizar este sitio web, usted acepta quedar vinculado por los presentes Términos y Condiciones. Si no está de acuerdo con alguna parte de estos términos, le rogamos que deje de utilizar este sitio web.',
  },

  's2.title':   { en: '2. Description of Service', es: '2. Descripción del Servicio' },
  's2.content': {
    en: 'This website is the professional portfolio of Jesús Antonio Castañeda Valencia, operating under the trade name <strong>CValenciaIT</strong>. Its purpose is informational — to present professional experience, skills, and projects. Content on this site does not constitute a binding offer of services.',
    es: 'Este sitio web es el portafolio profesional de Jesús Antonio Castañeda Valencia, que opera bajo el nombre comercial <strong>CValenciaIT</strong>. Su finalidad es informativa — presentar experiencia profesional, habilidades y proyectos. El contenido de este sitio no constituye una oferta de servicios vinculante.',
  },

  's3.title':   { en: '3. Intellectual Property', es: '3. Propiedad Intelectual' },
  's3.content': {
    en: 'All content on this website — including texts, design, visual identity, source code, and the CValenciaIT brand — is the exclusive property of Jesús Antonio Castañeda Valencia, protected under Colombian intellectual property law. Reproduction, distribution, or modification of any content without prior written consent is prohibited. Project descriptions referencing third-party organizations are used for attribution purposes only.',
    es: 'Todo el contenido de este sitio web — incluyendo textos, diseño, identidad visual, código fuente y la marca CValenciaIT — es propiedad exclusiva de Jesús Antonio Castañeda Valencia, protegida por la legislación colombiana de propiedad intelectual. Queda prohibida la reproducción, distribución o modificación de cualquier contenido sin autorización previa y por escrito. Las descripciones de proyectos que hacen referencia a organizaciones de terceros se utilizan exclusivamente con fines de atribución.',
  },

  's4.title':   { en: '4. Acceptable Use', es: '4. Uso Aceptable' },
  's4.content': {
    en: '<p class="mb-3">You agree not to use this website:</p><ul class="list-disc list-inside space-y-1 ml-2"><li>For any unlawful purpose or in violation of Colombian or international law.</li><li>To attempt to gain unauthorized access to the server or any associated systems.</li><li>To transmit malicious code or interfere with the proper functioning of the website.</li><li>To impersonate any person or entity.</li></ul>',
    es: '<p class="mb-3">Usted acepta no utilizar este sitio web:</p><ul class="list-disc list-inside space-y-1 ml-2"><li>Para ningún fin ilícito o que infrinja la legislación colombiana o internacional.</li><li>Para intentar obtener acceso no autorizado al servidor o a cualquier sistema asociado.</li><li>Para transmitir código malicioso o interferir con el correcto funcionamiento del sitio web.</li><li>Para suplantar la identidad de cualquier persona o entidad.</li></ul>',
  },

  's5.title':   { en: '5. Disclaimer of Warranties', es: '5. Exención de Garantías' },
  's5.content': {
    en: 'This website is provided "as is" and "as available" without warranties of any kind, either express or implied. We do not warrant that the website will be uninterrupted, error-free, or free of viruses or other harmful components.',
    es: 'Este sitio web se proporciona "tal cual" y "según disponibilidad", sin garantías de ningún tipo, expresas o implícitas. No garantizamos que el sitio web estará disponible de forma ininterrumpida, sin errores ni libre de virus u otros componentes dañinos.',
  },

  's6.title':   { en: '6. Limitation of Liability', es: '6. Limitación de Responsabilidad' },
  's6.content': {
    en: 'To the fullest extent permitted by applicable law, CValenciaIT shall not be liable for any direct, indirect, incidental, special, or consequential damages arising from your use of, or inability to use, this website or its content.',
    es: 'En la máxima medida permitida por la ley aplicable, CValenciaIT no será responsable de ningún daño directo, indirecto, incidental, especial o consecuente que surja del uso o la imposibilidad de uso de este sitio web o su contenido.',
  },

  's7.title':   { en: '7. Third-Party Links', es: '7. Vínculos a Terceros' },
  's7.content': {
    en: 'This website contains links to external websites (GitHub, LinkedIn, Meta/WhatsApp). These links are provided for convenience only. We have no control over and assume no responsibility for the content, privacy policies, or practices of any third-party websites.',
    es: 'Este sitio web contiene enlaces a sitios externos (GitHub, LinkedIn, Meta/WhatsApp). Estos enlaces se proporcionan únicamente por conveniencia. No tenemos control ni asumimos responsabilidad alguna por el contenido, las políticas de privacidad o las prácticas de ningún sitio web de terceros.',
  },

  's8.title':   { en: '8. WhatsApp Business', es: '8. WhatsApp Business' },
  's8.content': {
    en: 'Any WhatsApp Business channels linked from this website are subject to the WhatsApp Terms of Service and Meta\'s Supplemental Terms for Business. By initiating a conversation via WhatsApp, you acknowledge and accept those terms.',
    es: 'Los canales de WhatsApp Business enlazados desde este sitio web están sujetos a las Condiciones del Servicio de WhatsApp y los Términos Complementarios para Empresas de Meta. Al iniciar una conversación por WhatsApp, usted reconoce y acepta dichos términos.',
  },

  's9.title':   { en: '9. Modifications', es: '9. Modificaciones' },
  's9.content': {
    en: 'We reserve the right to modify these Terms & Conditions at any time. Changes take effect immediately upon posting. Your continued use of this website after any changes constitutes acceptance of the revised terms.',
    es: 'Nos reservamos el derecho de modificar estos Términos y Condiciones en cualquier momento. Los cambios entran en vigor de inmediato tras su publicación. El uso continuado de este sitio web tras cualquier modificación implica la aceptación de los términos revisados.',
  },

  's10.title':   { en: '10. Governing Law & Jurisdiction', es: '10. Ley Aplicable y Jurisdicción' },
  's10.content': {
    en: 'These Terms & Conditions are governed by and construed in accordance with the laws of the <strong>Republic of Colombia</strong>. Any disputes arising from or relating to these terms shall be subject to the exclusive jurisdiction of the courts of the city of Cali, Colombia.',
    es: 'Los presentes Términos y Condiciones se rigen e interpretan de conformidad con las leyes de la <strong>República de Colombia</strong>. Cualquier controversia que surja de o esté relacionada con estos términos estará sujeta a la jurisdicción exclusiva de los juzgados y tribunales de la ciudad de Cali, Colombia.',
  },

  's11.title':   { en: '11. Contact', es: '11. Contacto' },
  's11.content': {
    en: 'For any questions regarding these Terms & Conditions: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a>',
    es: 'Para cualquier consulta sobre estos Términos y Condiciones: <a href="mailto:jesus.a.castaneda.v@gmail.com" class="text-primary-container hover:underline">jesus.a.castaneda.v@gmail.com</a>',
  },
};

type Lang = 'en' | 'es';

function apply(lang: Lang) {
  document.documentElement.lang = lang;
  localStorage.setItem('lang', lang);
  document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
    const key = el.dataset.i18n!;
    if (t[key]?.[lang] !== undefined) el.innerHTML = t[key][lang];
  });
  document.querySelectorAll<HTMLElement>('.lang-toggle').forEach((btn) => {
    btn.textContent = lang === 'en' ? 'ES' : 'EN';
  });
}

const lang = (localStorage.getItem('lang') as Lang) ?? 'en';
apply(lang);
document.querySelectorAll('.lang-toggle').forEach((btn) => {
  btn.addEventListener('click', () => {
    apply((localStorage.getItem('lang') as Lang) === 'en' ? 'es' : 'en');
  });
});
</script>
